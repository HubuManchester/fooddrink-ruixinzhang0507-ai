<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:FoodMoment.Converters"
             x:Class="FoodMoment.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <converters:InvertedBoolConverter x:Key="InvertedBoolConverter" />
            <converters:BoolToTabColorConverter x:Key="BoolToTabColorConverter" />
            <converters:StringNotEmptyConverter x:Key="StringNotEmptyConverter" />
            <converters:FavoriteTextConverter x:Key="FavoriteTextConverter" />
            <converters:FavoriteBackgroundConverter x:Key="FavoriteBackgroundConverter" />
            <converters:FavoriteTextColorConverter x:Key="FavoriteTextColorConverter" />
            <converters:FavoriteHeartVisibilityConverter x:Key="FavoriteHeartVisibilityConverter" />
            <converters:RecipeImageSourceConverter x:Key="RecipeImageSourceConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
