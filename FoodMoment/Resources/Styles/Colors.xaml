<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Color x:Key="Primary">#E85D04</Color>
    <Color x:Key="PrimaryDark">#F48C06</Color>
    <Color x:Key="PrimaryDarkText">#1F2937</Color>
    <Color x:Key="Secondary">#FFF4EB</Color>
    <Color x:Key="SecondaryDarkText">#E85D04</Color>
    <Color x:Key="Tertiary">#6A994E</Color>
    <Color x:Key="Accent">#6A994E</Color>
    <Color x:Key="PageBackgroundLight">#F8F9FA</Color>
    <Color x:Key="PageBackgroundDark">#111827</Color>
    <Color x:Key="CardLight">#FFFFFF</Color>
    <Color x:Key="CardDark">#1F2937</Color>
    <Color x:Key="Danger">#DC2626</Color>
    <Color x:Key="DangerSurface">#FEE2E2</Color>
    <Color x:Key="Gray700">#374151</Color>
    <!-- Aliases used by default Styles.xaml (MAUI template names) -->
    <Color x:Key="MidnightBlue">#1F2937</Color>
    <Color x:Key="OffBlack">#111827</Color>
    <Color x:Key="Magenta">#E85D04</Color>

    <Color x:Key="White">White</Color>
    <Color x:Key="Black">Black</Color>
    <Color x:Key="Gray100">#F3F4F6</Color>
    <Color x:Key="Gray200">#E5E7EB</Color>
    <Color x:Key="Gray300">#D1D5DB</Color>
    <Color x:Key="Gray400">#9CA3AF</Color>
    <Color x:Key="Gray500">#6B7280</Color>
    <Color x:Key="Gray600">#4B5563</Color>
    <Color x:Key="Gray900">#111827</Color>
    <Color x:Key="Gray950">#030712</Color>

    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource Primary}" />
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource Secondary}" />
    <SolidColorBrush x:Key="WhiteBrush" Color="{StaticResource White}" />
    <SolidColorBrush x:Key="Gray200Brush" Color="{StaticResource Gray200}" />
    <SolidColorBrush x:Key="Gray500Brush" Color="{StaticResource Gray500}" />
</ResourceDictionary>
