<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:FoodMoment.ViewModels"
             xmlns:models="clr-namespace:FoodMoment.Models"
             x:Class="FoodMoment.Views.ExplorePage"
             x:DataType="vm:ExploreViewModel"
             Title="{Binding Title}"
             BackgroundColor="{AppThemeBinding Light={StaticResource PageBackgroundLight}, Dark={StaticResource PageBackgroundDark}}">

    <Grid RowDefinitions="Auto,Auto,*,Auto" Padding="20,16" RowSpacing="12">

        <VerticalStackLayout Grid.Row="0" Spacing="10">
            <Button Text="Get GPS location"
                    Command="{Binding GetLocationCommand}"
                    BackgroundColor="{StaticResource Primary}"
                    TextColor="White" />
            <ActivityIndicator IsRunning="{Binding IsBusy}" Color="{StaticResource Primary}" />
            <Label Text="{Binding LocationStatus}"
                   FontSize="14"
                   TextColor="{StaticResource Gray500}" />
            <Label Text="{Binding LatitudeText}"
                   FontSize="16"
                   FontAttributes="Bold"
                   TextColor="{AppThemeBinding Light={StaticResource PrimaryDarkText}, Dark=White}" />
            <Label Text="{Binding LongitudeText}"
                   FontSize="16"
                   FontAttributes="Bold"
                   TextColor="{AppThemeBinding Light={StaticResource PrimaryDarkText}, Dark=White}" />
            <Label Text="{Binding AddressText}"
                   FontSize="13"
                   TextColor="{StaticResource Gray500}" />
        </VerticalStackLayout>

        <Label Grid.Row="1"
               Text="Nearby food &amp; drink spots (demo data)"
               FontSize="14"
               TextColor="{StaticResource Gray500}" />

        <CollectionView Grid.Row="2"
                        ItemsSource="{Binding NearbyPlaces}">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:PlaceOfInterest">
                    <Border Margin="0,0,0,8"
                            Padding="12"
                            StrokeShape="RoundRectangle 12"
                            BackgroundColor="{AppThemeBinding Light={StaticResource CardLight}, Dark={StaticResource CardDark}}"
                            Stroke="{StaticResource Gray200}">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="{Binding Name}" FontSize="15" FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light={StaticResource PrimaryDarkText}, Dark=White}" />
                            <Label Text="{Binding Type}" FontSize="12" TextColor="{StaticResource Primary}" />
                            <Label Text="{Binding Address}" FontSize="12" TextColor="{StaticResource Gray500}" />
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
